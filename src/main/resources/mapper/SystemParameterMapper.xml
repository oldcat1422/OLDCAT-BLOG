<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jh.oldcat.mapper.SystemParameterMapper">

    <select id="getTotalNumber" resultType="com.jh.oldcat.entity.VO.TotalNumber">
        select article_number, tag_number, user_number, page_views from total_number
    </select>

    <select id="getAllPara" resultType="com.jh.oldcat.entity.SystemParameter">
        select * from system_parameter order by para_id
    </select>

</mapper>
